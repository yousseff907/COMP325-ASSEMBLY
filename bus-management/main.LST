                      00415 
0112                  00416 ROW3_KEY                        ; row 3: * 0 # D
0112   1C23           00417     BTFSS   TEMP,0
0113   342A           00418     RETLW   '*'
0114   1CA3           00419     BTFSS   TEMP,1
0115   3430           00420     RETLW   '0'
0116   1D23           00421     BTFSS   TEMP,2
0117   3423           00422     RETLW   '#'
0118   1DA3           00423     BTFSS   TEMP,3
0119   3444           00424     RETLW   'D'
011A   34FF           00425     RETLW   0xFF
                      00426 
                      00427 ;==========================================================
                      00428 ; DEBOUNCE - small delay (~few ms) using DEB_REG
                      00429 ; Does NOT touch TEMP (important - TEMP holds column bits)
                      00430 ;==========================================================
011B                  00431 DEBOUNCE
011B   30FA           00432     MOVLW   D'250'
011C   00A4           00433     MOVWF   DEB_REG
011D                  00434 DEB_LOOP
011D   0000           00435     NOP
011E   0000           00436     NOP
011F   0BA4           00437     DECFSZ  DEB_REG,F
0120   291D           00438     GOTO    DEB_LOOP
0121   0008           00439     RETURN
                      00440 
                      00441 ;==========================================================
                      00442 ; WAIT_RELEASE - call after detecting a key, waits until
                      00443 ; the user lets go before returning. Prevents one press
                      00444 ; from being read multiple times.
                      00445 ;==========================================================
0122                  00446 WAIT_RELEASE
0122   0186           00447     CLRF    PORTB               ; drive ALL rows LOW
0123   211B           00448     CALL    DEBOUNCE
0124   0806           00449     MOVF    PORTB,W
0125   390F           00450     ANDLW   B'00001111'         ; read column bits
0126   3A0F           00451     XORLW   B'00001111'         ; all HIGH = no key held
0127   1D03           00452     BTFSS   STATUS,Z
0128   2922           00453     GOTO    WAIT_RELEASE        ; key still held, wait
0129   0008           00454     RETURN
                      00455 
012A                  00456 GET_KEY
012A   20C5           00457     CALL    SCAN_KEY            ; one scan attempt
012B   0822           00458     MOVF    KEY_VAL,W
012C   3AFF           00459     XORLW   0xFF                ; compare to "no key"
012D   1903           00460     BTFSC   STATUS,Z
012E   292A           00461     GOTO    GET_KEY             ; nothing pressed, try again
012F   2122           00462     CALL    WAIT_RELEASE        ; wait for user to let go
0130   0822           00463     MOVF    KEY_VAL,W           ; load key into W for return
0131   0008           00464     RETURN
