                      00309 ; Scans the 4x4 keypad
                      00310 ; PORTB: B7-B4 = rows (outputs), B3-B0 = columns (inputs w/ pull-ups)
                      00311 ; Result: KEY_VAL holds ASCII of key pressed, or 0xFF if none
                      00312 ; Column mapping: B0=col0 (leftmost), B3=col3 (rightmost)
                      00313 ;==========================================================
00C5                  00314 SCAN_KEY
00C5   30FF           00315     MOVLW   0xFF
00C6   00A2           00316     MOVWF   KEY_VAL             ; default = no key pressed
                      00317 
                      00318     ; ---------- Row 0: drive B4 LOW ----------
00C7   307F           00319     MOVLW   B'01111111'
00C8   0086           00320     MOVWF   PORTB
00C9   211B           00321     CALL    DEBOUNCE
00CA   0806           00322     MOVF    PORTB,W
00CB   390F           00323     ANDLW   B'00001111'         ; isolate column bits
00CC   00A3           00324     MOVWF   TEMP                ; save for row handler
00CD   3A0F           00325     XORLW   B'00001111'         ; all 1s = no key in this row
00CE   1903           00326     BTFSC   STATUS,Z
00CF   28D3           00327     GOTO    ROW1_CHECK
00D0   20F7           00328     CALL    ROW0_KEY
00D1   00A2           00329     MOVWF   KEY_VAL             ; store returned ASCII
00D2   0008           00330     RETURN                      ; first key wins, exit
                      00331 
00D3                  00332 ROW1_CHECK
                      00333     ; ---------- Row 1: drive B5 LOW ----------
00D3   30BF           00334     MOVLW   B'10111111'
00D4   0086           00335     MOVWF   PORTB
00D5   211B           00336     CALL    DEBOUNCE
00D6   0806           00337     MOVF    PORTB,W
00D7   390F           00338     ANDLW   B'00001111'
00D8   00A3           00339     MOVWF   TEMP
00D9   3A0F           00340     XORLW   B'00001111'
00DA   1903           00341     BTFSC   STATUS,Z
00DB   28DF           00342     GOTO    ROW2_CHECK
00DC   2100           00343     CALL    ROW1_KEY
00DD   00A2           00344     MOVWF   KEY_VAL
00DE   0008           00345     RETURN
                      00346 
00DF                  00347 ROW2_CHECK
                      00348     ; ---------- Row 2: drive B6 LOW ----------
00DF   30DF           00349     MOVLW   B'11011111'
00E0   0086           00350     MOVWF   PORTB
00E1   211B           00351     CALL    DEBOUNCE
00E2   0806           00352     MOVF    PORTB,W
00E3   390F           00353     ANDLW   B'00001111'
00E4   00A3           00354     MOVWF   TEMP
00E5   3A0F           00355     XORLW   B'00001111'
00E6   1903           00356     BTFSC   STATUS,Z
00E7   28EB           00357     GOTO    ROW3_CHECK
00E8   2109           00358     CALL    ROW2_KEY
00E9   00A2           00359     MOVWF   KEY_VAL
00EA   0008           00360     RETURN
                      00361 
