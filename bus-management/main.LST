                      00377 ;==========================================================
                      00378 ; Row handlers
                      00379 ; TEMP holds masked column bits (only B3-B0 valid)
                      00380 ; Returns ASCII of pressed key in W
                      00381 ; Column mapping: B0=col0, B1=col1, B2=col2, B3=col3
                      00382 ;==========================================================
00F7                  00383 ROW0_KEY                        ; row 0: 1 2 3 A
00F7   1C23           00384     BTFSS   TEMP,0
00F8   3431           00385     RETLW   '1'
00F9   1CA3           00386     BTFSS   TEMP,1
00FA   3432           00387     RETLW   '2'
00FB   1D23           00388     BTFSS   TEMP,2
00FC   3433           00389     RETLW   '3'
00FD   1DA3           00390     BTFSS   TEMP,3
00FE   3441           00391     RETLW   'A'
00FF   34FF           00392     RETLW   0xFF                ; safety fallback
                      00393 
0100                  00394 ROW1_KEY                        ; row 1: 4 5 6 B
0100   1C23           00395     BTFSS   TEMP,0
0101   3434           00396     RETLW   '4'
0102   1CA3           00397     BTFSS   TEMP,1
0103   3435           00398     RETLW   '5'
0104   1D23           00399     BTFSS   TEMP,2
0105   3436           00400     RETLW   '6'
0106   1DA3           00401     BTFSS   TEMP,3
0107   3442           00402     RETLW   'B'
0108   34FF           00403     RETLW   0xFF
                      00404 
0109                  00405 ROW2_KEY                        ; row 2: 7 8 9 C
0109   1C23           00406     BTFSS   TEMP,0
010A   3437           00407     RETLW   '7'
010B   1CA3           00408     BTFSS   TEMP,1
010C   3438           00409     RETLW   '8'
010D   1D23           00410     BTFSS   TEMP,2
010E   3439           00411     RETLW   '9'
010F   1DA3           00412     BTFSS   TEMP,3
0110   3443           00413     RETLW   'C'
0111   34FF           00414     RETLW   0xFF
