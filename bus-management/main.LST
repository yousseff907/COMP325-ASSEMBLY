00BC                  00294 CHAR
00BC   1509           00295         BSF PORTE,2    ; RS=1 (this is a character, not command)
00BD   1009           00296         BCF PORTE,0    ; EN=0 (make SURE enable is low to start)
00BE   0088           00297         MOVWF PORTD    ; put the byte on the data bus
00BF   0000           00298         NOP            ; let data settle on PORTD
00C0   1409           00299         BSF PORTE,0    ; EN=1 (raise enable — "I'm presenting data")
00C1   0000           00300         NOP            ; hold high briefly
00C2   1009           00301         BCF PORTE,0    ; EN=0 (drop enable — LCD LATCHES the data HERE)
00C3   214C           00302         CALL DELAY3MS  ; wait for LCD to finish processing
00C4   0008           00303         RETURN
