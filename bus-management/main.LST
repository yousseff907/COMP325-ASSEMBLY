00EB                  00362 ROW3_CHECK
                      00363     ; ---------- Row 3: drive B7 LOW ----------
00EB   30EF           00364     MOVLW   B'11101111'
00EC   0086           00365     MOVWF   PORTB
00ED   211B           00366     CALL    DEBOUNCE
00EE   0806           00367     MOVF    PORTB,W
00EF   390F           00368     ANDLW   B'00001111'
00F0   00A3           00369     MOVWF   TEMP
00F1   3A0F           00370     XORLW   B'00001111'
00F2   1903           00371     BTFSC   STATUS,Z
00F3   0008           00372     RETURN                      ; nothing pressed, KEY_VAL stays 0xFF
00F4   2112           00373     CALL    ROW3_KEY
