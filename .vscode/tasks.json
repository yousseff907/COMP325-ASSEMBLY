{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build PIC16F877A",
            "type": "shell",
            "command": "mpasmx",
            "args": [
                "-p16f877a",
                "-w1",
                "-l",
                "-m",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": {
                "owner": "mpasm",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^(.*?)\\((\\d+)\\):\\s*(Error|Warning|Message)\\[(\\d+)\\]\\s*(.*)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "message": 5
                }
            }
        }
    ]
}